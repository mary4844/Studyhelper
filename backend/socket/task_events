async function emitTaskCreated(io, task, boardId) {
    io.to(String(boardId)).emit("task created", task);
}

async function emitAllTasksDeleted(io) {
    io.emit("all tasks deleted");
}

async function emitBoardTasksDeleted(io, boardId) {
    io.to(String(boardId)).emit("boardtasks deleted");
}

async function emitUpdatedTask(io, tasks, boardId) {
    io.to(String(boardId)).emit("task updated", tasks);
}

async function emitTaskDeleted(io, task, boardId) {
    io.to(String(boardId)).emit("task deleted", task);
}

module.exports = {
    emitTaskCreated,
    emitAllTasksDeleted,
    emitBoardTasksDeleted,
    emitUpdatedTask,
    emitTaskDeleted
}








